---
import { FilterTabs } from "@components/atoms/filter-tabs";
import { MomentCard } from "@components/features/diary";
import MainGridLayout from "@layouts/MainGridLayout.astro";

import { siteConfig } from "../config";
import { getAllTags, getDiaryList } from "../data/diary";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

if (!siteConfig.featurePages.diary) {
	return Astro.redirect("/404/");
}

const moments = getDiaryList();
const allTags = getAllTags();

const filterTabs = [
	{
		value: "all",
		label: i18n(I18nKey.albumsFilterAll),
		icon: "material-symbols:apps",
		count: moments.length,
	},
	...allTags.map((tag) => ({
		value: tag,
		label: tag,
		count: moments.filter((m) => m.tags && m.tags.includes(tag)).length,
	})),
];

const minutesAgo = i18n(I18nKey.diaryMinutesAgo);
const hoursAgo = i18n(I18nKey.diaryHoursAgo);
const daysAgo = i18n(I18nKey.diaryDaysAgo);

const title = i18n(I18nKey.diary);
const subtitle = i18n(I18nKey.diarySubtitle);
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import { loadIconify } from "../utils/icon-loader";

		loadIconify().catch((error) => {
			console.error("Failed to load Iconify:", error);
		});
	</script>

	<script is:inline src="/js/filter-tabs-handler.js"></script>

	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 relative w-full overflow-hidden">
			<div class="px-4 sm:px-6 md:px-8 pt-5 sm:pt-6">
				<div
					class="rounded-xl border border-[var(--primary)]/15 bg-[var(--primary)]/[0.06] p-4 sm:p-5"
				>
					<div class="flex items-start justify-between gap-4">
						<div class="min-w-0">
							<h1
								class="text-2xl sm:text-3xl font-bold leading-tight text-black/90 dark:text-white/90 mb-1"
							>
								{title}
							</h1>
							<p
								class="text-sm sm:text-base leading-relaxed text-black/60 dark:text-white/60"
							>
								{subtitle}
							</p>
						</div>
						<div
							class="shrink-0 text-right"
							aria-label={`${moments.length} ${i18n(I18nKey.diaryCount)}`}
						>
							<span
								class="block text-2xl sm:text-3xl font-bold leading-none text-[var(--primary)]"
							>
								{moments.length}
							</span>
							<span
								class="block mt-1 text-xs sm:text-sm text-black/55 dark:text-white/55"
							>
								{i18n(I18nKey.diaryCount)}
							</span>
						</div>
					</div>
				</div>
			</div>

			<div class="px-4 sm:px-6 md:px-8 pt-5 pb-6">
				{
					moments.length > 0 && allTags.length > 0 && (
						<div class="mb-6">
							<FilterTabs tabs={filterTabs} dataAttr="tags" />
						</div>
					)
				}

				<div id="diary-list" class="space-y-4">
					{
						moments.map((moment, index) => (
							<MomentCard
								moment={moment}
								index={index}
								minutesAgo={minutesAgo}
								hoursAgo={hoursAgo}
								daysAgo={daysAgo}
							/>
						))
					}
				</div>

				<div id="no-results" class="hidden text-center py-12">
					<iconify-icon
						icon="material-symbols:edit-note"
						width="64"
						height="64"
						class="text-black/25 dark:text-white/25 mb-4"
					></iconify-icon>
					<p class="text-black/60 dark:text-white/60 text-base">
						{i18n(I18nKey.diaryNoResults)}
					</p>
				</div>

				{
					moments.length === 0 && (
						<div class="text-center py-12">
							<iconify-icon
								icon="material-symbols:edit-note"
								width="64"
								height="64"
								class="text-black/25 dark:text-white/25 mb-4"
							/>
							<h3 class="text-lg font-medium text-black/90 dark:text-white/90 mb-2">
								{i18n(I18nKey.diaryNoResults)}
							</h3>
						</div>
					)
				}

				<div
					class="text-center mt-8 text-black/60 dark:text-white/60 text-sm"
				>
					{i18n(I18nKey.diaryTips)}
				</div>
			</div>
		</div>
	</div>
</MainGridLayout>
