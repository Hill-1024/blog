---
import DeviceCard from "@components/features/devices/DeviceCard.astro";
import { Icon } from "astro-icon/components";

import { siteConfig } from "../config";
import { devicesData } from "../data/devices";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

export const prerender = true;

if (!siteConfig.featurePages.devices) {
	return Astro.redirect("/404/");
}

const devices = Object.entries(devicesData).flatMap(([brand, entries]) =>
	entries.map((device) => ({ ...device, brand })),
);
const brands = Object.keys(devicesData);
const categories = [...new Set(devices.map((device) => device.category))];
---

<MainGridLayout title={i18n(I18nKey.devices)} minimal>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<section class="devices-page card-base" data-devices-page>
		<header class="devices-heading">
			<h1>{i18n(I18nKey.devices)}</h1>
			<p>{i18n(I18nKey.devicesSubtitle)}</p>
		</header>

		<section
			class="device-tag-filter"
			data-device-filters
			aria-label="设备标签筛选"
		>
			<label class="device-filter-label" for="device-tag-search">
				搜索或选择标签
			</label>
			<div class="device-filter-combobox" data-device-combobox>
				<div class="device-tag-searchbox" data-device-searchbox>
					<Icon
						name="material-symbols:search-rounded"
						class="device-search-icon"
						aria-hidden="true"
					/>
					<div class="device-active-tags" data-device-active-tags>
					</div>
					<input
						id="device-tag-search"
						data-device-search
						type="text"
						inputmode="search"
						autocomplete="off"
						role="combobox"
						aria-autocomplete="list"
						aria-controls="device-tag-catalogue"
						aria-expanded="false"
						aria-haspopup="listbox"
						aria-label="搜索并添加设备筛选标签"
						placeholder="搜索设备，或选择标签"
					/>
					<button
						type="button"
						class="device-clear-filters"
						data-device-clear
						aria-label="清除所有筛选"
						hidden
					>
						清除
					</button>
				</div>

				<div
					id="device-tag-catalogue"
					class="device-tag-catalogue"
					data-device-catalogue
					role="listbox"
					aria-label="可用设备标签"
					aria-multiselectable="true"
					hidden
				>
					<div
						class="device-tag-group"
						role="group"
						aria-labelledby="device-category-label"
					>
						<p id="device-category-label">品类</p>
						<div class="device-tag-options">
							{
								categories.map((category) => (
									<button
										type="button"
										class="device-tag"
										data-device-tag
										data-tag-group="category"
										data-tag-value={category}
										role="option"
										aria-selected="false"
										tabindex="-1"
									>
										{category}
									</button>
								))
							}
						</div>
					</div>

					<div
						class="device-tag-group"
						role="group"
						aria-labelledby="device-brand-label"
					>
						<p id="device-brand-label">品牌</p>
						<div class="device-tag-options">
							{
								brands.map((brand) => (
									<button
										type="button"
										class="device-tag"
										data-device-tag
										data-tag-group="brand"
										data-tag-value={brand}
										role="option"
										aria-selected="false"
										tabindex="-1"
									>
										{brand}
									</button>
								))
							}
						</div>
					</div>
					<p class="device-tag-empty" data-device-tag-empty hidden>
						没有匹配的标签
					</p>
				</div>
			</div>
		</section>

		<p
			class="device-result-summary"
			aria-live="polite"
			data-device-result-summary
		>
			{devices.length} 件设备
		</p>

		<div class="device-grid" data-device-grid>
			{
				devices.map((device) => (
					<DeviceCard device={device} brand={device.brand} />
				))
			}
		</div>

		<p class="device-empty-state" data-device-empty-state hidden>
			没有符合当前筛选条件的设备。
		</p>
	</section>

	<script is:inline src="/js/devices-page-handler.js"></script>
</MainGridLayout>

<style>
	.devices-page {
		padding: clamp(1.25rem, 3vw, 2.5rem);
		container-type: inline-size;
	}

	.devices-heading {
		max-width: 42rem;
		padding-bottom: 1.6rem;
		border-bottom: 1px solid var(--line-divider);
	}

	.devices-heading h1 {
		margin: 0;
		color: color-mix(in oklab, var(--deep-text) 92%, var(--primary));
		font-size: clamp(1.75rem, 4vw, 2.35rem);
		font-weight: 750;
		letter-spacing: -0.035em;
		line-height: 1.15;
	}

	:global(.dark) .devices-heading h1 {
		color: color-mix(in oklab, white 90%, var(--primary));
	}

	.devices-heading p {
		margin: 0.65rem 0 0;
		color: var(--content-meta);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.device-tag-filter {
		padding: 1.35rem 0 0.4rem;
	}

	.device-tag-group > p {
		margin: 0;
		color: var(--content-meta);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.045em;
	}

	.device-filter-label {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		overflow: hidden;
		clip: rect(0 0 0 0);
		white-space: nowrap;
		border: 0;
	}

	.device-filter-combobox {
		position: relative;
		z-index: 5;
		width: min(100%, 42rem);
	}

	.device-tag-searchbox {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.35rem;
		min-height: 3rem;
		padding: 0.35rem 0.45rem 0.35rem 0.78rem;
		border: 1px solid
			color-mix(in oklab, var(--line-divider) 88%, var(--content-meta));
		border-radius: 0.85rem;
		background: var(--card-bg);
		box-shadow: 0 1px 2px
			color-mix(in srgb, var(--deep-text) 4%, transparent);
		cursor: text;
		transition:
			border-color 150ms ease,
			box-shadow 150ms ease;
	}

	.device-tag-searchbox:focus-within {
		border-color: color-mix(
			in oklab,
			var(--primary) 46%,
			var(--line-divider)
		);
		box-shadow: 0 0 0 3px
			color-mix(in oklab, var(--primary) 10%, transparent);
	}

	:global(.device-search-icon) {
		flex: none;
		width: 1.15rem;
		height: 1.15rem;
		margin: 0 0.12rem 0 0;
		color: var(--content-meta);
	}

	.device-tag-searchbox input {
		flex: 1 1 12rem;
		min-width: 7rem;
		min-height: 2.15rem;
		padding: 0.2rem 0.12rem;
		border: 0;
		outline: 0;
		background: transparent;
		color: var(--deep-text);
		font: inherit;
		font-size: 0.92rem;
	}

	.device-tag-searchbox input::placeholder {
		color: color-mix(in oklab, var(--content-meta) 78%, transparent);
	}

	.device-active-tags,
	.device-tag-options {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.device-active-tags {
		display: contents;
	}

	.device-active-tags:empty {
		display: none;
	}

	:global(.device-active-tag),
	.device-tag,
	.device-clear-filters {
		min-height: 2rem;
		border: 1px solid
			color-mix(in oklab, var(--line-divider) 80%, transparent);
		background: color-mix(
			in oklab,
			var(--btn-regular-bg) 76%,
			var(--card-bg)
		);
		color: var(--content-meta);
		cursor: pointer;
		font: inherit;
		font-size: 0.8rem;
		font-weight: 600;
		line-height: 1;
	}

	.device-tag {
		padding: 0.42rem 0.75rem;
		border-radius: 999px;
		box-shadow: none;
	}

	.device-tag:hover {
		border-color: color-mix(
			in oklab,
			var(--primary) 35%,
			var(--line-divider)
		);
		background: color-mix(in oklab, var(--primary) 7%, var(--card-bg));
		color: var(--btn-content);
	}

	.device-tag.keyboard-active {
		border-color: color-mix(
			in oklab,
			var(--primary) 58%,
			var(--line-divider)
		);
		background: color-mix(in oklab, var(--primary) 10%, var(--card-bg));
		box-shadow: 0 0 0 2px
			color-mix(in oklab, var(--primary) 12%, transparent);
		color: var(--btn-content);
	}

	.device-tag.selected,
	:global(.device-active-tag) {
		border-color: color-mix(in oklab, var(--primary) 28%, transparent);
		background: color-mix(in oklab, var(--primary) 10%, var(--card-bg));
		color: var(--btn-content);
	}

	.device-tag.selected::before {
		content: "✓";
		margin-right: 0.32rem;
		color: var(--primary);
		font-size: 0.75rem;
	}

	:global(.device-active-tag) {
		display: inline-flex;
		align-items: center;
		flex: none;
		gap: 0.3rem;
		padding: 0.38rem 0.48rem 0.38rem 0.68rem;
		border-radius: 999px;
		box-shadow: none;
		white-space: nowrap;
	}

	:global(.device-active-tag-remove) {
		color: var(--content-meta);
		font-size: 1rem;
		font-weight: 400;
		line-height: 0.8;
	}

	.device-clear-filters {
		flex: none;
		padding: 0.38rem 0.62rem;
		border-color: transparent;
		border-radius: 999px;
		background: transparent;
		color: var(--content-meta);
	}

	.device-clear-filters:hover {
		background: color-mix(in oklab, var(--btn-regular-bg) 70%, transparent);
		color: var(--btn-content);
	}

	.device-tag-catalogue {
		position: absolute;
		top: calc(100% + 0.4rem);
		left: 0;
		right: 0;
		display: grid;
		gap: 0.75rem;
		max-height: min(23rem, 55vh);
		padding: 0.85rem;
		overflow-y: auto;
		overscroll-behavior: contain;
		border: 1px solid
			color-mix(in oklab, var(--line-divider) 88%, transparent);
		border-radius: 0.85rem;
		background: color-mix(in oklab, var(--card-bg) 97%, var(--page-bg));
		box-shadow:
			0 1rem 2.5rem color-mix(in srgb, var(--deep-text) 11%, transparent),
			0 1px 4px color-mix(in srgb, var(--deep-text) 5%, transparent);
		isolation: isolate;
	}

	.device-tag-catalogue[hidden] {
		display: none;
	}

	.device-tag-group {
		display: flex;
		align-items: baseline;
		gap: 0.9rem;
	}

	.device-tag-group > p {
		flex: 0 0 2.5rem;
		padding-top: 0.55rem;
	}

	.device-tag-options {
		flex: 1;
	}

	.device-tag[hidden] {
		display: none;
	}

	.device-tag-empty {
		margin: 0;
		padding: 0.55rem 0.65rem;
		color: var(--content-meta);
		font-size: 0.8rem;
		line-height: 1.5;
	}

	.device-tag-empty[hidden] {
		display: none;
	}

	.device-tag:focus-visible,
	:global(.device-active-tag):focus-visible,
	.device-clear-filters:focus-visible {
		outline: 2px solid color-mix(in oklab, var(--primary) 58%, transparent);
		outline-offset: 2px;
	}

	.device-result-summary {
		margin: 0.8rem 0 1rem;
		color: var(--content-meta);
		font-size: 0.82rem;
	}

	.device-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 30rem), 1fr));
		gap: 1rem;
	}

	.device-empty-state {
		margin: 2.5rem 0 0;
		padding: 2rem;
		border: 1px dashed var(--line-divider);
		border-radius: 0.875rem;
		color: var(--content-meta);
		text-align: center;
	}

	@container (max-width: 44rem) {
		.device-tag-group {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.45rem;
		}

		.device-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.devices-page {
			padding: 1.1rem;
		}

		.device-tag-filter {
			padding-top: 1.1rem;
		}

		.device-tag-searchbox {
			min-height: 3.25rem;
			padding: 0.35rem 0.4rem 0.35rem 0.7rem;
			border-radius: 0.82rem;
		}

		.device-tag-searchbox input {
			min-height: 2.4rem;
			min-width: 6.5rem;
		}

		:global(.device-active-tag),
		.device-tag,
		.device-clear-filters {
			min-height: 44px;
		}

		.device-clear-filters {
			padding-inline: 0.65rem;
		}

		.device-tag-catalogue {
			max-height: min(25rem, 58svh);
			padding: 0.72rem;
		}

		.device-tag-group {
			gap: 0.35rem;
		}

		.device-tag-options {
			width: 100%;
		}
	}
</style>
