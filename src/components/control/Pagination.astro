---
import type { Page } from "astro";
import { Icon } from "astro-icon/components";

import { url } from "../../utils/url-utils";

interface Props {
	page: Page;
	class?: string;
	style?: string;
}

const { page, style } = Astro.props;

const HIDDEN = -1;

const className = Astro.props.class;

const ADJ_DIST = 2;
const VISIBLE = ADJ_DIST * 2 + 1;

// for test
let count = 1;
let l = page.currentPage;
let r = page.currentPage;
while (0 < l - 1 && r + 1 <= page.lastPage && count + 2 <= VISIBLE) {
	count += 2;
	l--;
	r++;
}
while (0 < l - 1 && count < VISIBLE) {
	count++;
	l--;
}
while (r + 1 <= page.lastPage && count < VISIBLE) {
	count++;
	r++;
}

const pages: number[] = [];
if (l > 1) {
	pages.push(1);
}
if (l === 3) {
	pages.push(2);
}
if (l > 3) {
	pages.push(HIDDEN);
}
for (let i = l; i <= r; i++) {
	pages.push(i);
}
if (r < page.lastPage - 2) {
	pages.push(HIDDEN);
}
if (r === page.lastPage - 2) {
	pages.push(page.lastPage - 1);
}
if (r < page.lastPage) {
	pages.push(page.lastPage);
}

const getPageUrl = (p: number) => {
	if (p === 1) {
		return "/";
	}
	return `/${p}/`;
};
---

<div
	class:list={[
		className,
		"flex w-full min-w-0 flex-row justify-center gap-2 sm:gap-3",
	]}
	style={style}
>
	<a
		href={page.url.prev || ""}
		aria-label="上一页"
		aria-disabled={page.url.prev == undefined ? "true" : undefined}
		tabindex={page.url.prev == undefined ? -1 : undefined}
		class:list={[
			"btn-card h-11 w-11 shrink-0 overflow-hidden rounded-lg text-[var(--primary)]",
			{ disabled: page.url.prev == undefined },
		]}
	>
		<Icon
			name="material-symbols:chevron-left-rounded"
			class="text-[1.75rem]"
		/>
	</a>
	<div
		class="hidden flex-row items-center rounded-lg bg-[var(--card-bg)] font-bold text-neutral-700 sm:flex dark:text-neutral-300"
	>
		{
			pages.map((p) => {
				if (p == HIDDEN) {
					return (
						<Icon name="material-symbols:more-horiz" class="mx-1" />
					);
				}
				if (p == page.currentPage) {
					return (
						<div
							class="h-11 w-11 rounded-lg bg-[var(--primary)] flex items-center justify-center
                    font-bold text-white dark:text-black/70"
						>
							{p}
						</div>
					);
				}
				return (
					<a
						href={url(getPageUrl(p))}
						aria-label={`Page ${p}`}
						class="btn-card w-11 h-11 rounded-lg overflow-hidden active:scale-[0.85]"
					>
						{p}
					</a>
				);
			})
		}
	</div>
	<div
		class="flex h-11 min-w-0 max-w-40 flex-1 items-center justify-center gap-1.5 rounded-lg bg-[var(--card-bg)] px-3 font-bold text-neutral-700 sm:hidden dark:text-neutral-300"
		aria-label={`第 ${page.currentPage} 页，共 ${page.lastPage} 页`}
	>
		<span class="text-[var(--primary)]" aria-current="page">
			{page.currentPage}
		</span>
		<span aria-hidden="true" class="text-[var(--meta-divider)]">/</span>
		<span>{page.lastPage}</span>
	</div>
	<a
		href={page.url.next || ""}
		aria-label="下一页"
		aria-disabled={page.url.next == undefined ? "true" : undefined}
		tabindex={page.url.next == undefined ? -1 : undefined}
		class:list={[
			"btn-card h-11 w-11 shrink-0 overflow-hidden rounded-lg text-[var(--primary)]",
			{ disabled: page.url.next == undefined },
		]}
	>
		<Icon
			name="material-symbols:chevron-right-rounded"
			class="text-[1.75rem]"
		/>
	</a>
</div>
