---
/**
 * ButtonTag - 标签按钮组件
 *
 * 用于标签列表的紧凑链接按钮，支持圆点指示器。
 * 这是一个特定用途的组件，新的通用按钮需求请使用 atoms/Button。
 */
interface ButtonTagProps {
	size?: string;
	dot?: boolean;
	href?: string;
	label?: string;
}
const { dot, href, label }: ButtonTagProps = Astro.props;
---

<a
	href={href}
	aria-label={label}
	class="button-tag btn-regular h-8 rounded-lg px-3 text-sm"
>
	{
		dot && (
			<div class="h-1 w-1 bg-[var(--btn-content)] dark:bg-[var(--card-bg)] transition rounded-md mr-2" />
		)
	}
	<slot />
</a>

<style>
	@media (pointer: coarse) {
		.button-tag {
			min-width: 2.75rem;
			min-height: 2.75rem;
		}
	}
</style>
