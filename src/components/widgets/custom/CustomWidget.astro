---
import WidgetLayout from "../common/WidgetLayout.astro";

interface Props {
	id?: string;
	title?: string;
	icon?: string;
	content?: string;
	html?: string;
	href?: string;
	linkLabel?: string;
	external?: boolean;
	class?: string;
	style?: string;
}

const {
	id = "custom-widget",
	title = "自定义组件",
	icon = "material-symbols:widgets-outline-rounded",
	content = "",
	html,
	href,
	linkLabel = "了解更多",
	external = false,
	style,
} = Astro.props;
const className = Astro.props.class;
const instanceId = `${id}-${Math.random().toString(36).slice(2, 9)}`;
---

<WidgetLayout id={instanceId} name={title} class={className} style={style}>
	<iconify-icon
		slot="title-icon"
		icon={icon}
		width="20"
		height="20"
		class="ml-2 text-[var(--primary)]"
		aria-hidden="true"></iconify-icon>
	<div class="custom-widget-content text-sm leading-relaxed text-75">
		{
			// `html` is trusted, build-time content from src/config.ts only.
			html ? (
				<div set:html={html} />
			) : content ? (
				<p class="whitespace-pre-wrap">{content}</p>
			) : null
		}
		{
			href && (
				<a
					href={href}
					target={external ? "_blank" : undefined}
					rel={external ? "noopener noreferrer" : undefined}
					class="mt-3 inline-flex min-h-11 items-center rounded-lg px-3 py-2 font-medium text-[var(--primary)] transition-colors hover:bg-[var(--btn-regular-bg-hover)]"
				>
					{linkLabel}
				</a>
			)
		}
	</div>
</WidgetLayout>

<style>
	.custom-widget-content :global(a) {
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.2em;
	}
</style>
