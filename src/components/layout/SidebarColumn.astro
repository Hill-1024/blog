---
import { SidebarTOC } from "@components/features/toc";
import type { MarkdownHeading } from "astro";

import { widgetManager } from "@/utils/widget-manager";
import { buildComponentProps } from "@/utils/widget-renderer";

import Announcement from "../widgets/announcement/Announcement.astro";
import Calendar from "../widgets/calendar/Calendar.astro";
import { CardTOC } from "../widgets/card-toc";
import Categories from "../widgets/categories/Categories.astro";
import { CustomWidget } from "../widgets/custom";
import MusicPlayer from "../widgets/music-player/MusicPlayer.svelte";
import { MusicSidebarWidget } from "../widgets/music-sidebar";
import Profile from "../widgets/profile/Profile.astro";
import SiteStats from "../widgets/site-stats/SiteStats.astro";
import Tags from "../widgets/tags/Tags.astro";

interface Props {
	side: "left" | "right";
	headings?: MarkdownHeading[];
	containerId?: string;
	stickyId?: string;
	rootClass?: string;
	topClass?: string;
	stickyClass?: string;
	showMobile?: boolean;
	showTablet?: boolean;
	showDesktop?: boolean;
}

const {
	side,
	headings,
	containerId,
	stickyId,
	rootClass = "w-full",
	topClass = "",
	stickyClass = "",
	showMobile = false,
	showTablet = true,
	showDesktop = true,
} = Astro.props;

const componentMap: Record<string, unknown> = {
	profile: Profile,
	announcement: Announcement,
	categories: Categories,
	tags: Tags,
	toc: SidebarTOC,
	"card-toc": CardTOC,
	"music-player": MusicPlayer,
	"music-sidebar": MusicSidebarWidget,
	"site-stats": SiteStats,
	calendar: Calendar,
	custom: CustomWidget,
};

type WidgetComponentConfig = ReturnType<
	typeof widgetManager.getComponentsByPosition
>[number];

const mobileTopComponents = showMobile
	? widgetManager.getComponentsByPosition("top", side, "mobile")
	: [];
const mobileStickyComponents = showMobile
	? widgetManager.getComponentsByPosition("sticky", side, "mobile")
	: [];
const mobileOrder = widgetManager.getConfig().components.drawer;
const mobileComponents = [
	...mobileTopComponents,
	...mobileStickyComponents,
].sort((a, b) => mobileOrder.indexOf(a.type) - mobileOrder.indexOf(b.type));

const tabletTopComponents = showTablet
	? widgetManager.getComponentsByPosition("top", side, "tablet")
	: [];
const tabletStickyComponents = showTablet
	? widgetManager.getComponentsByPosition("sticky", side, "tablet")
	: [];

const desktopTopComponents = showDesktop
	? widgetManager.getComponentsByPosition("top", side, "desktop")
	: [];
const desktopStickyComponents = showDesktop
	? widgetManager.getComponentsByPosition("sticky", side, "desktop")
	: [];

function renderComponent(
	component: WidgetComponentConfig,
	index: number,
): { Component: any; props: Record<string, unknown> } | null {
	const ComponentToRender = componentMap[component.type] as any;
	if (!ComponentToRender) {
		throw new Error(
			`Sidebar widget "${component.type}" is not registered in SidebarColumn`,
		);
	}

	return {
		Component: ComponentToRender,
		props: buildComponentProps(component, index, headings),
	};
}
---

<div
	id={containerId}
	class:list={[rootClass, "sidebar-column-root", "min-w-0"]}
>
	<div class:list={["flex flex-col w-full gap-4 mb-4", topClass]}>
		{
			showMobile && mobileComponents.length > 0 && (
				<details class="mobile-sidebar-drawer card-base md:hidden">
					<summary class="flex min-h-11 cursor-pointer list-none items-center justify-between gap-3 px-4 py-2.5 font-semibold text-90">
						<span>更多内容</span>
						<iconify-icon
							icon="material-symbols:keyboard-arrow-down-rounded"
							class="mobile-sidebar-drawer-arrow text-lg text-[var(--primary)]"
							aria-hidden="true"
						/>
					</summary>
					<div class="flex flex-col w-full gap-4 border-t border-black/5 p-3 dark:border-white/10">
						{mobileComponents.map((component, index) => {
							const renderData = renderComponent(
								component,
								index,
							);
							if (!renderData) {
								return null;
							}

							const { Component, props } = renderData;
							return <Component {...props} />;
						})}
					</div>
				</details>
			)
		}

		{
			showTablet && tabletTopComponents.length > 0 && (
				<div class="sidebar-content hidden md:flex min-[1280px]:hidden flex-col w-full gap-4">
					{tabletTopComponents.map((component, index) => {
						const renderData = renderComponent(component, index);
						if (!renderData) {
							return null;
						}

						const { Component, props } = renderData;
						return <Component {...props} />;
					})}
				</div>
			)
		}

		{
			showDesktop && desktopTopComponents.length > 0 && (
				<div class="sidebar-content hidden min-[1280px]:flex flex-col w-full gap-4">
					{desktopTopComponents.map((component, index) => {
						const renderData = renderComponent(component, index);
						if (!renderData) {
							return null;
						}

						const { Component, props } = renderData;
						return <Component {...props} />;
					})}
				</div>
			)
		}
	</div>

	<div
		id={stickyId}
		class:list={[
			"transition-all duration-700 flex flex-col w-full min-w-0 gap-4 sticky sidebar-sticky-column",
			stickyClass,
		]}
	>
		{
			showTablet && tabletStickyComponents.length > 0 && (
				<div class="sidebar-content hidden md:flex min-[1280px]:hidden flex-col w-full gap-4">
					{tabletStickyComponents.map((component, index) => {
						const renderData = renderComponent(component, index);
						if (!renderData) {
							return null;
						}

						const { Component, props } = renderData;
						return <Component {...props} />;
					})}
				</div>
			)
		}

		{
			showDesktop && desktopStickyComponents.length > 0 && (
				<div class="sidebar-content hidden min-[1280px]:flex flex-col w-full gap-4">
					{desktopStickyComponents.map((component, index) => {
						const renderData = renderComponent(component, index);
						if (!renderData) {
							return null;
						}

						const { Component, props } = renderData;
						return <Component {...props} />;
					})}
				</div>
			)
		}
	</div>
</div>

<style>
	.mobile-sidebar-drawer > summary::-webkit-details-marker {
		display: none;
	}

	.mobile-sidebar-drawer-arrow {
		transition: rotate 180ms ease;
	}

	.mobile-sidebar-drawer[open] .mobile-sidebar-drawer-arrow {
		rotate: 180deg;
	}
</style>
