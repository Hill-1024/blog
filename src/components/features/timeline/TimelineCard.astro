---
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import type { TimelineCardProps } from "./types";

const { item } = Astro.props as TimelineCardProps;

const isCurrent = !item.endDate;

const getTypeIcon = (type: string) => {
	switch (type) {
		case "education":
			return "material-symbols:school";
		case "work":
			return "material-symbols:work";
		case "project":
			return "material-symbols:code";
		case "achievement":
			return "material-symbols:emoji-events";
		default:
			return "material-symbols:event";
	}
};

const getTypeText = (type: string) => {
	switch (type) {
		case "education":
			return i18n(I18nKey.timelineEducation);
		case "work":
			return i18n(I18nKey.timelineWork);
		case "project":
			return i18n(I18nKey.timelineProject);
		case "achievement":
			return i18n(I18nKey.timelineAchievement);
		default:
			return type;
	}
};

const getLinkIcon = (type: string) => {
	switch (type) {
		case "certificate":
			return "material-symbols:verified";
		case "project":
			return "material-symbols:open-in-new";
		case "website":
			return "material-symbols:language";
		default:
			return "material-symbols:description";
	}
};

const formatDate = (dateString: string) => {
	const date = new Date(dateString);
	return date.toLocaleDateString("zh-CN", {
		year: "numeric",
		month: "short",
	});
};

const getDuration = (startDate: string, endDate?: string) => {
	const start = new Date(startDate);
	const end = endDate ? new Date(endDate) : new Date();
	const diffTime = Math.abs(end.getTime() - start.getTime());
	const diffMonths = Math.ceil(diffTime / (1000 * 60 * 60 * 24 * 30));

	if (diffMonths < 12) {
		return `${diffMonths} ${i18n(I18nKey.timelineMonths)}`;
	}
	const years = Math.floor(diffMonths / 12);
	const months = diffMonths % 12;
	if (months === 0) {
		return `${years} ${i18n(I18nKey.timelineYears)}`;
	}
	return `${years} ${i18n(I18nKey.timelineYears)} ${months} ${i18n(I18nKey.timelineMonths)}`;
};

const icon = item.icon || getTypeIcon(item.type);
const typeText = getTypeText(item.type);
const dateRange = `${formatDate(item.startDate)} - ${item.endDate ? formatDate(item.endDate) : i18n(I18nKey.timelinePresent)}`;
const duration = getDuration(item.startDate, item.endDate);
const nodeColor = isCurrent ? "#22c55e" : item.color || "var(--primary)";
const hasLinks = item.links && item.links.length > 0;
---

<div
	class:list={["timeline-entry", { "is-current": isCurrent }]}
	data-type={item.type}
>
	<div class="timeline-node" style={`background-color: ${nodeColor};`}>
		<iconify-icon icon={icon} width="10" height="10" style="color: white;"
		></iconify-icon>
	</div>

	<div
		class="timeline-card group relative rounded-xl border border-black/10 dark:border-white/10 overflow-hidden transition-colors duration-200 hover:border-[var(--primary)]/35"
	>
		<div class="p-4 sm:p-5 md:p-6">
			<div class="flex flex-wrap items-start gap-3 mb-3">
				<div
					class="w-10 h-10 flex-shrink-0 rounded-lg flex items-center justify-center bg-[var(--btn-regular-bg)]"
				>
					<iconify-icon
						icon={icon}
						width="20"
						height="20"
						style={`color: ${item.color || "var(--primary)"};`}
					></iconify-icon>
				</div>

				<div
					class="flex-1 min-w-0 basis-[calc(100%_-_3.25rem)] sm:basis-auto"
				>
					<div class="flex items-center gap-2 mb-0.5">
						<h2
							class="text-lg font-bold text-black/90 dark:text-white/90 group-hover:text-[var(--primary)] transition-colors duration-200"
						>
							{item.title}
						</h2>
						{
							item.featured && (
								<iconify-icon
									icon="material-symbols:star-rounded"
									width="16"
									height="16"
									class="text-[var(--primary)] flex-shrink-0"
								/>
							)
						}
					</div>
					{
						item.organization && (
							<p class="text-sm text-black/60 dark:text-white/60">
								{item.organization}
								{item.position ? ` · ${item.position}` : ""}
							</p>
						)
					}
				</div>

				<div
					class="flex w-full items-center gap-1.5 pl-[3.25rem] sm:w-auto sm:pl-0 sm:ml-2"
				>
					{
						isCurrent && (
							<span class="px-2 py-0.5 text-xs rounded-md bg-green-500/10 text-green-600 dark:text-green-400 font-medium">
								{i18n(I18nKey.timelineCurrent)}
							</span>
						)
					}
					<span
						class="px-2 py-0.5 text-xs rounded-md bg-[var(--primary)]/10 text-[var(--primary)] font-medium"
					>
						{typeText}
					</span>
				</div>
			</div>

			<p
				class="text-sm text-black/70 dark:text-white/70 mb-4 leading-relaxed"
			>
				{item.description}
			</p>

			{
				item.skills && item.skills.length > 0 && (
					<div class="flex flex-wrap gap-2 mb-4">
						{item.skills.map((skill) => (
							<span class="px-2 py-1 text-xs rounded-md bg-[var(--primary)]/10 text-[var(--primary)] font-medium">
								{skill}
							</span>
						))}
					</div>
				)
			}

			{
				item.achievements && item.achievements.length > 0 && (
					<div class="mb-4">
						<h3 class="text-xs font-semibold text-black/50 dark:text-white/50 uppercase tracking-wider mb-2">
							{i18n(I18nKey.timelineAchievements)}
						</h3>
						<ul class="space-y-1.5">
							{item.achievements.map((achievement) => (
								<li class="text-sm text-black/70 dark:text-white/70 flex items-start gap-2">
									<iconify-icon
										icon="material-symbols:check-circle"
										width="16"
										height="16"
										class="text-green-500 flex-shrink-0 mt-0.5"
									/>
									<span>{achievement}</span>
								</li>
							))}
						</ul>
					</div>
				)
			}

			<div
				class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-black/60 dark:text-white/60 mb-1 pt-3 border-t border-black/10 dark:border-white/10"
			>
				<span class="flex items-center gap-1">
					<iconify-icon
						icon="material-symbols:calendar-month-outline"
						width="14"
						height="14"></iconify-icon>
					{dateRange}
				</span>
				<span class="flex items-center gap-1">
					<iconify-icon
						icon="material-symbols:schedule-outline"
						width="14"
						height="14"></iconify-icon>
					{duration}
				</span>
				{
					item.location && (
						<span class="flex items-center gap-1">
							<iconify-icon
								icon="material-symbols:location-on-outline"
								width="14"
								height="14"
							/>
							{item.location}
						</span>
					)
				}
			</div>

			{
				hasLinks && (
					<div class="flex flex-wrap gap-2 mt-3">
						{item.links!.map((link) => (
							<a
								href={link.url}
								target="_blank"
								rel="noopener noreferrer"
								class="btn-regular min-h-11 flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-medium"
							>
								<iconify-icon
									icon={getLinkIcon(link.type)}
									width="14"
									height="14"
								/>
								{link.name}
							</a>
						))}
					</div>
				)
			}
		</div>
	</div>
</div>

<style>
	.timeline-entry {
		position: relative;
		padding-left: 2rem;
		padding-bottom: 1.5rem;
	}

	.timeline-entry:last-child {
		padding-bottom: 0;
	}

	.timeline-entry.filtered-out {
		display: none;
	}

	.timeline-node {
		position: absolute;
		left: 0;
		top: 1.5rem;
		width: 1.25rem;
		height: 1.25rem;
		border-radius: 50%;
		border: 2.5px solid white;
		box-shadow: 0 0 0 2px var(--line-divider);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 2;
		transition: box-shadow 0.2s ease;
	}
</style>
