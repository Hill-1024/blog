---
import type { PhotoCardProps } from "./types";

const { src, alt = "", albumId } = Astro.props as PhotoCardProps;
---

<div class="gallery-photo-card break-inside-avoid mb-3">
	<a
		href={src}
		data-fancybox={`gallery-${albumId}`}
		data-src={src}
		data-type="image"
		class="block rounded-xl overflow-hidden group cursor-zoom-in"
		aria-label={alt ? `查看大图：${alt}` : "查看大图"}
	>
		<img
			src={src}
			alt={alt}
			loading="lazy"
			decoding="async"
			class="w-full h-auto object-cover"
		/>
	</a>
</div>
