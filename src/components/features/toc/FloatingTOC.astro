---
import type { MarkdownHeading } from "astro";

import { Icon } from "astro-icon/components";

import FloatingButton from "@components/common/FloatingButton.astro";
import { siteConfig } from "../../../config";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";

interface Props {
	headings?: MarkdownHeading[];
}

const { headings: _ = [] } = Astro.props;
const tocDepth = siteConfig.toc.depth;
const useJapaneseBadge = siteConfig.toc.useJapaneseBadge;
---

<div
	class="floating-toc-wrapper"
	data-depth={tocDepth}
	data-japanese-badge={useJapaneseBadge}
>
	<FloatingButton
		id="floating-toc-btn"
		icon="material-symbols:format-list-bulleted-rounded"
		ariaLabel={i18n(I18nKey.tableOfContents)}
		class="hide"
	/>
	<nav
		id="floating-toc-panel"
		class="floating-toc-panel"
		aria-label={i18n(I18nKey.tableOfContents)}
		aria-hidden="true"
		inert
	>
		<div class="floating-toc-header">
			<p class="text-lg font-bold text-(--primary)">
				{i18n(I18nKey.tableOfContents)}
			</p>
			<button
				type="button"
				data-floating-toc-close
				aria-label="关闭目录"
				class="btn-plain rounded-lg h-8 w-8 active:scale-90"
			>
				<Icon name="material-symbols:close" class="text-lg" />
			</button>
		</div>
		<div class="floating-toc-panel-content" id="floating-toc-content"></div>
	</nav>
</div>

<style>
	.floating-toc-wrapper {
		position: relative;
		z-index: 51;
		pointer-events: auto;
	}

	.floating-toc-panel {
		position: absolute;
		bottom: calc(100% + 0.75rem);
		right: 0;
		width: 18rem;
		max-height: 60vh;
		background: var(--card-bg);
		border: 1px solid var(--line-color);
		border-radius: 1rem;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
		overflow: hidden;
		opacity: 0;
		visibility: hidden;
		transform: translateY(10px) scale(0.95);
		transition: all 0.2s ease;
		pointer-events: none;
		z-index: 52;
	}

	.floating-toc-panel.show {
		opacity: 1;
		visibility: visible;
		transform: translateY(0) scale(1);
		pointer-events: auto;
	}

	.floating-toc-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1rem;
		border-bottom: 1px solid var(--line-color);
		background: var(--card-bg);
	}

	.floating-toc-panel-content {
		padding: 0.75rem;
		max-height: calc(60vh - 3rem);
		overflow-y: auto;
		overflow-x: hidden;
	}

	.floating-toc-panel-content::-webkit-scrollbar {
		width: 4px;
	}

	.floating-toc-panel-content::-webkit-scrollbar-track {
		background: transparent;
	}

	.floating-toc-panel-content::-webkit-scrollbar-thumb {
		background: var(--line-color);
		border-radius: 2px;
	}

	@media (max-width: 768px) {
		.floating-toc-panel {
			width: 85vw;
			max-width: 20rem;
			right: 0;
		}
	}

	:global(.floating-toc-item) {
		display: flex;
		align-items: center;
		padding: 0.5rem;
		color: var(--content-meta);
		text-decoration: none;
		font-size: 0.9rem;
		line-height: 1.5;
		border-radius: 0.5rem;
		transition: all 0.2s;
	}

	:global(.floating-toc-item:hover) {
		background-color: var(--btn-regular-bg);
		color: var(--primary);
	}

	:global(.floating-toc-item.active) {
		background-color: var(--btn-card-bg-active);
		color: var(--primary);
		font-weight: 500;
	}

	:global(.floating-toc-badge) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.25rem;
		height: 1.25rem;
		background: var(--btn-regular-bg);
		color: var(--primary);
		border-radius: 0.25rem;
		font-size: 0.75rem;
		font-weight: bold;
		margin-right: 0.5rem;
		flex-shrink: 0;
	}

	:global(.floating-toc-dot) {
		width: 0.5rem;
		height: 0.5rem;
		background: var(--line-divider);
		border-radius: 50%;
		margin-right: 0.75rem;
		margin-left: 0.375rem;
		flex-shrink: 0;
	}

	:global(.floating-toc-dot-small) {
		width: 0.35rem;
		height: 0.35rem;
		background: var(--line-divider);
		border-radius: 50%;
		margin-right: 0.75rem;
		margin-left: 0.45rem;
		flex-shrink: 0;
	}

	:global(.floating-toc-item.active .floating-toc-dot),
	:global(.floating-toc-item.active .floating-toc-dot-small) {
		background: var(--primary);
	}

	:global(.floating-toc-text) {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
</style>

<script>
	import { findActiveHeadingIndex } from "./hooks/useTocHighlight";
	import { throttle } from "./hooks/useTocScroll";
	import {
		generateTOCItems,
		getTOCConfig,
		scrollToHeading,
	} from "./utils/toc-utils";

	interface FloatingTOCState {
		btn: HTMLElement | null;
		panel: HTMLElement | null;
		content: HTMLElement | null;
		wrapper: HTMLElement | null;
		isOpen: boolean;
		observer: MutationObserver | null;
		headings: HTMLElement[];
	}

	class FloatingTOC {
		state: FloatingTOCState;
		navbarOffset = 80;
		private boundButton: HTMLElement | null = null;
		private boundCloseButton: HTMLButtonElement | null = null;
		private boundContent: HTMLElement | null = null;
		private handleScroll = throttle(() => this.updateActiveHeading(), 50);

		private handleButtonClick = (event: Event) => {
			event.stopPropagation();
			this.toggle();
		};

		private handleCloseClick = () => this.close(true);

		private handleDocumentClick = (event: MouseEvent) => {
			if (
				this.state.isOpen &&
				!this.state.wrapper?.contains(event.target as Node)
			) {
				this.close();
			}
		};

		private handleKeydown = (event: KeyboardEvent) => {
			if (event.key === "Escape" && this.state.isOpen) {
				event.preventDefault();
				this.close(true);
			}
		};

		private handleContentClick = (event: Event) => {
			if (!(event.target instanceof Element)) return;
			const link = event.target.closest("a[data-target-id]");
			if (!(link instanceof HTMLAnchorElement)) return;

			event.preventDefault();
			const id = link.dataset.targetId;
			if (id) {
				scrollToHeading(id, this.navbarOffset);
				this.close();
			}
		};

		constructor() {
			this.state = {
				btn: document.getElementById("floating-toc-btn"),
				panel: document.getElementById("floating-toc-panel"),
				content: document.getElementById("floating-toc-content"),
				wrapper: document.querySelector(".floating-toc-wrapper"),
				isOpen: false,
				observer: null,
				headings: [],
			};
			this.init();
		}

		init() {
			window.addEventListener("scroll", this.handleScroll, {
				passive: true,
			});
			window.addEventListener("resize", this.handleScroll, {
				passive: true,
			});
			document.addEventListener("click", this.handleDocumentClick);
			document.addEventListener("keydown", this.handleKeydown);

			this.bindControlEvents();
			this.generateTOC();
			this.observeContent();
		}

		private get trigger(): HTMLButtonElement | null {
			return this.state.btn?.querySelector("button") ?? null;
		}

		private syncTriggerAccessibility() {
			const trigger = this.trigger;
			trigger?.setAttribute("aria-controls", "floating-toc-panel");
			trigger?.setAttribute("aria-expanded", String(this.state.isOpen));
		}

		private bindControlEvents() {
			this.unbindControlEvents();

			this.boundButton = this.state.btn;
			this.boundCloseButton =
				this.state.panel?.querySelector<HTMLButtonElement>(
					"[data-floating-toc-close]",
				) ?? null;
			this.boundContent = this.state.content;

			this.boundButton?.addEventListener("click", this.handleButtonClick);
			this.boundCloseButton?.addEventListener(
				"click",
				this.handleCloseClick,
			);
			this.boundContent?.addEventListener(
				"click",
				this.handleContentClick,
			);
			this.syncTriggerAccessibility();
		}

		private unbindControlEvents() {
			this.boundButton?.removeEventListener(
				"click",
				this.handleButtonClick,
			);
			this.boundCloseButton?.removeEventListener(
				"click",
				this.handleCloseClick,
			);
			this.boundContent?.removeEventListener(
				"click",
				this.handleContentClick,
			);
			this.boundButton = null;
			this.boundCloseButton = null;
			this.boundContent = null;
		}

		observeContent() {
			this.state.observer?.disconnect();
			const contentWrapper = document.getElementById("post-container");
			if (contentWrapper) {
				this.state.observer = new MutationObserver(() => {
					this.generateTOC();
				});
				this.state.observer.observe(contentWrapper, {
					childList: true,
					subtree: true,
				});
			}
		}

		updateActiveHeading() {
			const { content, headings } = this.state;
			if (!content || headings.length === 0) return;

			const activeIndex = Math.max(
				0,
				findActiveHeadingIndex(headings, window.scrollY, 150),
			);
			const links = Array.from(
				content.querySelectorAll(".floating-toc-item"),
			) as HTMLAnchorElement[];

			links.forEach((link, index) => {
				if (index === activeIndex) {
					link.classList.add("active");
					link.setAttribute("aria-current", "location");
					if (this.state.isOpen) {
						const panelRect = content.getBoundingClientRect();
						const linkRect = link.getBoundingClientRect();
						if (
							linkRect.top < panelRect.top ||
							linkRect.bottom > panelRect.bottom
						) {
							link.scrollIntoView({ block: "nearest" });
						}
					}
				} else {
					link.classList.remove("active");
					link.removeAttribute("aria-current");
				}
			});
		}

		private setNoTOC() {
			this.close();
			this.state.wrapper?.classList.remove("active-toc");
			this.state.wrapper?.classList.add("no-toc");
			this.state.btn?.classList.add("hide");
			this.state.content?.replaceChildren();
			this.state.headings = [];
		}

		generateTOC() {
			const container = document.getElementById("post-container");
			const { wrapper, btn } = this.state;

			if (!container) {
				this.setNoTOC();
				return;
			}

			const allHeadings = container.querySelectorAll(
				"h1[id], h2[id], h3[id], h4[id], h5[id], h6[id]",
			);

			if (allHeadings.length === 0) {
				this.setNoTOC();
				return;
			}

			wrapper?.classList.remove("no-toc");
			wrapper?.classList.add("active-toc");
			btn?.classList.remove("hide");

			const headings = Array.from(allHeadings) as HTMLElement[];
			const config = getTOCConfig();
			const tocItems = generateTOCItems(
				headings.map((h) => ({
					id: h.id,
					text: (h.textContent || "").replace(/#+\s*$/, ""),
					level: parseInt(h.tagName[1], 10),
				})),
				config,
			);

			if (tocItems.length === 0 || !this.state.content) {
				this.setNoTOC();
				return;
			}

			this.state.headings = tocItems
				.map((item) => document.getElementById(item.id))
				.filter((heading): heading is HTMLElement => heading !== null);

			// Build with DOM APIs so heading text never becomes executable markup.
			const fragment = document.createDocumentFragment();
			tocItems.forEach((item) => {
				const link = document.createElement("a");
				link.href = `#${encodeURIComponent(item.id)}`;
				link.className = "floating-toc-item";
				link.style.paddingLeft = `${0.5 + item.depth}rem`;
				link.dataset.level = String(item.depth);
				link.dataset.targetId = item.id;

				const marker = document.createElement("span");
				marker.className =
					item.depth === 0
						? "floating-toc-badge"
						: item.depth === 1
							? "floating-toc-dot"
							: "floating-toc-dot-small";
				if (item.depth === 0) marker.textContent = item.badge || "";

				const label = document.createElement("span");
				label.className = "floating-toc-text";
				label.textContent = item.text;

				link.append(marker, label);
				fragment.append(link);
			});

			this.state.content.replaceChildren(fragment);
			this.updateActiveHeading();
		}

		toggle() {
			this.state.isOpen ? this.close() : this.open();
		}

		open() {
			if (this.state.headings.length === 0) return;
			this.state.isOpen = true;
			this.state.panel?.classList.add("show");
			this.state.panel?.setAttribute("aria-hidden", "false");
			this.state.panel?.removeAttribute("inert");
			this.state.btn?.classList.add("active");
			this.state.wrapper?.classList.add("active");
			this.syncTriggerAccessibility();
		}

		close(restoreFocus = false) {
			this.state.isOpen = false;
			this.state.panel?.classList.remove("show");
			this.state.panel?.setAttribute("aria-hidden", "true");
			this.state.panel?.setAttribute("inert", "");
			this.state.btn?.classList.remove("active");
			this.state.wrapper?.classList.remove("active");
			this.syncTriggerAccessibility();
			if (restoreFocus) this.trigger?.focus();
		}

		reinit() {
			this.state.observer?.disconnect();
			this.close();
			this.unbindControlEvents();
			this.state.btn = document.getElementById("floating-toc-btn");
			this.state.panel = document.getElementById("floating-toc-panel");
			this.state.content = document.getElementById(
				"floating-toc-content",
			);
			this.state.wrapper = document.querySelector(
				".floating-toc-wrapper",
			);
			this.bindControlEvents();
			this.generateTOC();
			this.observeContent();
		}
	}

	let floatingTOCInstance: FloatingTOC | null = null;
	let registeredSwup: Swup | undefined;

	function initFloatingTOC() {
		if (floatingTOCInstance) {
			floatingTOCInstance.reinit();
		} else {
			floatingTOCInstance = new FloatingTOC();
		}
	}

	const handlePageView = (..._args: unknown[]) => initFloatingTOC();
	const registerSwup = () => {
		const swup = window.swup;
		if (!swup || swup === registeredSwup) return;
		registeredSwup?.hooks.off("page:view", handlePageView);
		swup.hooks.on("page:view", handlePageView);
		registeredSwup = swup;
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initFloatingTOC, {
			once: true,
		});
	} else {
		initFloatingTOC();
	}
	document.addEventListener("astro:page-load", initFloatingTOC);
	document.addEventListener("swup:enable", registerSwup);
	registerSwup();
</script>
