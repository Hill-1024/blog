---
/**
 * Desktop TOC. Heading depth is always calculated relative to the first
 * article heading, so an article that begins at h2 behaves exactly like one
 * that begins at h1.
 */
import "@/styles/toc.css";
---

<table-of-contents
	class="group"
	id="toc"
	role="navigation"
	aria-label="文章目录"></table-of-contents>

<script>
	import {
		calculateActiveIndicatorPosition,
		throttle,
	} from "./hooks/useTocScroll";
	import {
		extractHeadings,
		generateTOCItems,
		getTOCConfig,
		scrollToHeading,
	} from "./utils/toc-utils";

	const escapeHtml = (value: string) =>
		value
			.replace(/&/g, "&amp;")
			.replace(/</g, "&lt;")
			.replace(/>/g, "&gt;")
			.replace(/\"/g, "&quot;")
			.replace(/'/g, "&#39;");

	class TableOfContents extends HTMLElement {
		scrollContainer: HTMLElement | null = null;
		headings: HTMLElement[] = [];
		entries: HTMLAnchorElement[] = [];
		indicator: HTMLElement | null = null;
		activeIndex = -1;
		navbarHeight = 88;
		initialized = false;

		onScroll = throttle(() => this.updateActiveHeading(), 60);

		connectedCallback() {
			window.setTimeout(() => this.initialise(), 80);
		}

		disconnectedCallback() {
			this.cleanup();
			this.toggleLayoutState(false);
		}

		cleanup() {
			window.removeEventListener("scroll", this.onScroll);
			window.removeEventListener("resize", this.onScroll);
			this.removeEventListener("click", this.handleAnchorClick);
			this.initialized = false;
		}

		/** Public compatibility entrypoint used by Swup. */
		init() {
			this.refresh();
		}

		refresh() {
			this.cleanup();
			this.activeIndex = -1;
			this.entries = [];
			this.headings = [];
			this.indicator = null;
			this.initialise();
		}

		toggleLayoutState(hasToc: boolean) {
			document
				.getElementById("main-grid")
				?.classList.toggle("article-toc-active", hasToc);
			this.toggleAttribute("data-loaded", hasToc);
		}

		initialise() {
			if (!this.isConnected || this.initialized) return;
			this.initialized = true;
			this.regenerateTOC();
			this.scrollContainer =
				(this.closest("#toc-inner-wrapper") as HTMLElement | null) ||
				this;
			this.entries = Array.from(
				this.querySelectorAll<HTMLAnchorElement>("a[href^='#']"),
			);
			this.headings = this.entries
				.map((entry) => {
					const id = decodeURIComponent(entry.hash.slice(1));
					return document.getElementById(id);
				})
				.filter(
					(heading): heading is HTMLElement =>
						heading instanceof HTMLElement,
				);
			this.indicator = this.querySelector("[data-sidebar-toc-indicator]");

			if (
				this.entries.length !== this.headings.length ||
				this.entries.length === 0
			) {
				this.innerHTML = "";
				this.toggleLayoutState(false);
				return;
			}
			this.toggleLayoutState(true);

			this.addEventListener("click", this.handleAnchorClick);
			window.addEventListener("scroll", this.onScroll, { passive: true });
			window.addEventListener("resize", this.onScroll, { passive: true });
			this.updateActiveHeading();
		}

		regenerateTOC() {
			const headings = extractHeadings();
			if (headings.length === 0) {
				this.innerHTML = "";
				this.toggleLayoutState(false);
				return;
			}

			const items = generateTOCItems(headings, getTOCConfig());
			this.innerHTML =
				items
					.map((item) => {
						const label = escapeHtml(item.text);
						const badge =
							item.depth === 0
								? `<span class="toc-badge toc-badge-index">${escapeHtml(item.badge || "")}</span>`
								: item.depth === 1
									? '<span class="toc-badge toc-badge-dot"></span>'
									: '<span class="toc-badge toc-badge-dot toc-badge-dot-sm"></span>';

						return `<a href="#${encodeURIComponent(item.id)}" data-no-swup class="toc-item toc-level-${item.depth}" data-depth="${item.depth}" title="${label}">${badge}<span class="toc-label ${item.depth <= 1 ? "toc-label-primary" : "toc-label-secondary"}">${label}</span></a>`;
					})
					.join("") +
				'<span data-sidebar-toc-indicator class="toc-active-indicator" aria-hidden="true"></span>';
		}

		handleAnchorClick = (event: Event) => {
			const anchor = (event.target as Element | null)?.closest(
				"a[href^='#']",
			);
			if (!(anchor instanceof HTMLAnchorElement)) return;

			event.preventDefault();
			const id = decodeURIComponent(anchor.hash.slice(1));
			const index = this.entries.indexOf(anchor);
			if (index >= 0) this.setActive(index);
			window.history.replaceState(window.history.state, "", anchor.hash);
			scrollToHeading(id, this.navbarHeight);
		};

		updateActiveHeading() {
			if (this.headings.length === 0) return;

			let nextIndex = 0;
			const marker = this.navbarHeight + 24;
			this.headings.forEach((heading, index) => {
				if (heading.getBoundingClientRect().top <= marker)
					nextIndex = index;
			});
			this.setActive(nextIndex);
		}

		setActive(index: number) {
			if (this.activeIndex === index) return;
			this.activeIndex = index;
			this.entries.forEach((entry, entryIndex) => {
				const active = entryIndex === index;
				entry.classList.toggle("visible", active);
				if (active) entry.setAttribute("aria-current", "location");
				else entry.removeAttribute("aria-current");
			});

			const entry = this.entries[index];
			if (!entry || !this.indicator) return;
			const position = calculateActiveIndicatorPosition(
				this,
				entry,
				entry,
			);
			this.indicator.style.opacity = "1";
			this.indicator.style.top = `${position.top}px`;
			this.indicator.style.height = `${position.height}px`;
			this.keepActiveEntryVisible(entry);
		}

		keepActiveEntryVisible(entry: HTMLElement) {
			if (!this.scrollContainer) return;
			const container = this.scrollContainer.getBoundingClientRect();
			const item = entry.getBoundingClientRect();
			if (item.top >= container.top && item.bottom <= container.bottom)
				return;

			this.scrollContainer.scrollTo({
				top:
					entry.offsetTop -
					this.scrollContainer.clientHeight / 2 +
					entry.clientHeight / 2,
				behavior: window.matchMedia("(prefers-reduced-motion: reduce)")
					.matches
					? "auto"
					: "smooth",
			});
		}
	}

	if (!customElements.get("table-of-contents")) {
		customElements.define("table-of-contents", TableOfContents);
	}
</script>

<style>
	table-of-contents#toc {
		display: block;
		max-height: 100%;
		overflow: auto;
		position: relative;
		scroll-behavior: smooth;
	}

	table-of-contents#toc::-webkit-scrollbar {
		display: none;
	}
</style>
