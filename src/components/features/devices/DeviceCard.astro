---
import { Icon } from "astro-icon/components";

import type { Device } from "../../../data/devices";

interface Props {
	device: Device;
	brand: string;
}

const { device, brand } = Astro.props;

const categoryPresentation: Record<string, { variant: string; icon: string }> =
	{
		电脑: {
			variant: "computer",
			icon: "material-symbols:laptop-mac",
		},
		手机: {
			variant: "phone",
			icon: "material-symbols:smartphone",
		},
		平板电脑: {
			variant: "tablet",
			icon: "material-symbols:tablet-mac",
		},
		耳机: {
			variant: "audio",
			icon: "material-symbols:headphones-rounded",
		},
	};

const presentation = categoryPresentation[device.category] ?? {
	variant: "generic",
	icon: "material-symbols:devices-other-rounded",
};
---

<a
	href={device.link}
	target="_blank"
	rel="noopener noreferrer"
	class:list={["device-card", `device-card--${presentation.variant}`]}
	data-device-card
	data-brand={brand}
	data-category={device.category}
	data-device-kind={presentation.variant}
	aria-label={`查看 ${device.name} 的官网`}
>
	<div class="device-card-media">
		<img
			src={device.image}
			alt={device.name}
			loading="lazy"
			decoding="async"
		/>
	</div>

	<div class="device-card-body">
		<div class="device-card-heading">
			<div>
				<p class="device-card-context">
					<Icon name={presentation.icon} aria-hidden="true" />
					<span>{device.category}</span>
					<span
						class="device-card-context-separator"
						aria-hidden="true">·</span
					>
					<span>{brand}</span>
				</p>
				<h2>{device.name}</h2>
			</div>
			<Icon
				name="material-symbols:arrow-outward-rounded"
				class="device-card-arrow"
				aria-hidden="true"
			/>
		</div>

		<dl class="device-specs">
			{
				device.specs.map((spec) => (
					<div class="device-spec-row">
						<dt>
							<Icon
								name={
									spec.icon ||
									"material-symbols:info-outline-rounded"
								}
								aria-hidden="true"
							/>
							<span>{spec.label}</span>
						</dt>
						<dd>{spec.value}</dd>
					</div>
				))
			}
		</dl>

		<p class="device-card-description">{device.description}</p>
	</div>
</a>

<style>
	.device-card {
		--device-accent: var(--primary);
		--device-media-columns: minmax(9rem, 0.78fr) minmax(0, 1.22fr);
		--device-media-surface: color-mix(
			in oklab,
			var(--btn-regular-bg) 74%,
			var(--card-bg)
		);
		display: grid;
		grid-template-columns: var(--device-media-columns);
		min-height: 15.5rem;
		overflow: hidden;
		border: 1px solid var(--line-divider);
		border-radius: 0.875rem;
		background: var(--card-bg);
		color: inherit;
		text-decoration: none;
		transition:
			border-color 160ms ease,
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.device-card:hover,
	.device-card:focus-visible {
		border-color: color-mix(
			in oklab,
			var(--device-accent) 46%,
			var(--line-divider)
		);
		box-shadow: 0 0.75rem 2rem
			color-mix(in srgb, var(--device-accent) 10%, transparent);
		transform: translateY(-0.2rem);
		outline: none;
	}

	.device-card:focus-visible {
		box-shadow: 0 0 0 0.2rem
			color-mix(in oklab, var(--device-accent) 35%, transparent);
	}

	.device-card--computer {
		--device-accent: color-mix(in oklab, var(--primary) 68%, #4169e1);
		--device-media-columns: minmax(10rem, 0.9fr) minmax(0, 1.1fr);
	}

	.device-card--phone {
		--device-accent: color-mix(in oklab, var(--primary) 66%, #16a36a);
		--device-media-columns: minmax(8.5rem, 0.68fr) minmax(0, 1.32fr);
	}

	.device-card--tablet {
		--device-accent: color-mix(in oklab, var(--primary) 66%, #7c5bd6);
		--device-media-columns: minmax(9.5rem, 0.84fr) minmax(0, 1.16fr);
	}

	.device-card--audio {
		--device-accent: color-mix(in oklab, var(--primary) 64%, #c67825);
		--device-media-columns: minmax(9rem, 0.76fr) minmax(0, 1.24fr);
	}

	.device-card-media {
		display: grid;
		place-items: center;
		min-width: 0;
		padding: 1.25rem;
		background: color-mix(
			in oklab,
			var(--device-accent) 7%,
			var(--device-media-surface)
		);
		box-shadow: inset -1px 0 0
			color-mix(in oklab, var(--line-divider) 70%, transparent);
	}

	.device-card-media img {
		width: 100%;
		height: 100%;
		max-height: 12.5rem;
		object-fit: contain;
		filter: drop-shadow(0 0.45rem 0.7rem rgb(0 0 0 / 0.1));
		transition: transform 220ms ease;
	}

	.device-card--phone .device-card-media img {
		max-width: 72%;
	}

	.device-card--tablet .device-card-media img {
		max-width: 88%;
	}

	.device-card--audio .device-card-media img {
		max-width: 84%;
	}

	.device-card:hover .device-card-media img {
		transform: scale(1.035);
	}

	.device-card-body {
		display: flex;
		min-width: 0;
		flex-direction: column;
		padding: 1.25rem 1.35rem;
	}

	.device-card-heading {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 0.85rem;
	}

	.device-card-context {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.28rem;
		margin: 0 0 0.32rem;
		color: color-mix(
			in oklab,
			var(--device-accent) 72%,
			var(--btn-content)
		);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	.device-card-context :global(svg) {
		width: 1rem;
		height: 1rem;
	}

	.device-card-context-separator {
		color: var(--content-meta);
		font-weight: 400;
	}

	.device-card h2 {
		margin: 0;
		color: color-mix(in oklab, var(--deep-text) 92%, var(--primary));
		font-size: 1.05rem;
		font-weight: 700;
		line-height: 1.35;
	}

	:global(.dark) .device-card h2 {
		color: color-mix(in oklab, white 90%, var(--primary));
	}

	:global(.device-card-arrow) {
		flex: none;
		margin-top: 0.08rem;
		color: color-mix(
			in oklab,
			var(--device-accent) 72%,
			var(--btn-content)
		);
		font-size: 1.15rem;
		opacity: 0.75;
		transition: transform 160ms ease;
	}

	.device-card:hover :global(.device-card-arrow) {
		transform: translate(0.15rem, -0.15rem);
	}

	.device-specs {
		margin: 0;
		border-top: 1px solid var(--line-divider);
	}

	.device-spec-row {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
		gap: 0.65rem;
		padding: 0.48rem 0;
		border-bottom: 1px solid var(--line-divider);
		font-size: 0.78rem;
		line-height: 1.25rem;
	}

	.device-spec-row dt {
		display: flex;
		min-width: 0;
		align-items: center;
		gap: 0.42rem;
		color: var(--content-meta);
	}

	.device-spec-row dt :global(svg) {
		flex: none;
		width: 1rem;
		height: 1rem;
		color: color-mix(
			in oklab,
			var(--device-accent) 72%,
			var(--btn-content)
		);
	}

	.device-spec-row dd {
		margin: 0;
		min-width: 0;
		color: color-mix(in oklab, var(--content-meta) 88%, var(--primary));
		font-weight: 600;
		text-align: right;
		word-break: break-word;
	}

	.device-card-description {
		margin: auto 0 0;
		padding-top: 0.85rem;
		color: color-mix(in oklab, var(--content-meta) 78%, transparent);
		font-size: 0.8rem;
		line-height: 1.45;
	}

	@media (max-width: 520px) {
		.device-card {
			grid-template-columns: 1fr;
		}

		.device-card-media {
			min-height: 11.5rem;
			box-shadow: inset 0 -1px 0
				color-mix(in oklab, var(--line-divider) 70%, transparent);
		}

		.device-card-media img {
			max-height: 9.75rem;
		}

		.device-card--phone .device-card-media img {
			max-width: 58%;
		}
	}
</style>
