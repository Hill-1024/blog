---
import { commentConfig } from "@/config";

interface Props {
	path: string;
}

const config = {
	...commentConfig.giscus,
	term: Astro.props.path,
};
---

<div id="giscus-container" class="giscus-container"></div>

<script is:inline define:vars={{ config }}>
	(function () {
		const GISCUS_CONTAINER_ID = "giscus-container";
		const GISCUS_CONTROLLER_KEY = "__mizukiGiscus";
		const ROOT_MARGIN = "200px";

		let observer = null;
		let themeObserver = null;
		let swupContentReplaceHandler = null;
		let swupEnableHandler = null;
		let pageLoadedHandler = null;

		if (window[GISCUS_CONTROLLER_KEY]?.destroy) {
			window[GISCUS_CONTROLLER_KEY].destroy();
		}

		function normalizeTerm(term) {
			const normalized = String(term || "")
				.trim()
				.replace(/^\/+/, "");

			if (!normalized) {
				return "";
			}

			return normalized.endsWith("/") ? normalized : `${normalized}/`;
		}

		function getGiscusTerm() {
			return normalizeTerm(config.term);
		}

		async function initGiscus() {
			const container = document.getElementById(GISCUS_CONTAINER_ID);
			if (!container) {
				return;
			}

			let theme = config.theme;
			if (theme === "preferred_color_scheme") {
				const isDark =
					document.documentElement.classList.contains("dark") ||
					document.documentElement
						.getAttribute("data-theme")
						?.includes("dark");
				theme = isDark ? "dark" : "light";
			}

			container.innerHTML = "";

			const script = document.createElement("script");
			script.src = "https://giscus.app/client.js";
			script.setAttribute("data-repo", config.repo);
			script.setAttribute("data-repo-id", config.repoId);
			script.setAttribute("data-category", config.category);
			script.setAttribute("data-category-id", config.categoryId);
			script.setAttribute("data-mapping", "specific");
			script.setAttribute("data-term", getGiscusTerm());
			script.setAttribute("data-strict", config.strict);
			script.setAttribute(
				"data-reactions-enabled",
				config.reactionsEnabled,
			);
			script.setAttribute("data-emit-metadata", config.emitMetadata);
			script.setAttribute("data-input-position", config.inputPosition);
			script.setAttribute("data-theme", theme);
			script.setAttribute(
				"data-lang",
				config.lang ? config.lang.replace("_", "-") : "en",
			);
			script.setAttribute("data-loading", config.loading);
			script.crossOrigin = "anonymous";
			script.async = true;

			container.appendChild(script);
		}

		function cleanup() {
			if (observer) {
				observer.disconnect();
				observer = null;
			}
			if (themeObserver) {
				themeObserver.disconnect();
				themeObserver = null;
			}
			if (window.swup?.hooks && swupContentReplaceHandler) {
				window.swup.hooks.off(
					"content:replace",
					swupContentReplaceHandler,
				);
			}
			if (swupEnableHandler) {
				document.removeEventListener("swup:enable", swupEnableHandler);
			}
			if (pageLoadedHandler) {
				document.removeEventListener(
					"mizuki:page:loaded",
					pageLoadedHandler,
				);
			}
			swupContentReplaceHandler = null;
			swupEnableHandler = null;
			pageLoadedHandler = null;
		}

		function setupLazyLoad() {
			const container = document.getElementById(GISCUS_CONTAINER_ID);
			if (!container) {
				return;
			}

			observer = new IntersectionObserver(
				(entries) => {
					if (entries[0].isIntersecting) {
						observer.disconnect();
						observer = null;
						initGiscus();
					}
				},
				{ rootMargin: ROOT_MARGIN },
			);

			observer.observe(container);
		}

		function setupSwupHooks() {
			if (swupContentReplaceHandler) {
				return;
			}

			swupContentReplaceHandler = () => {
				setTimeout(setupLazyLoad, 200);
			};

			if (window.swup?.hooks) {
				window.swup.hooks.on(
					"content:replace",
					swupContentReplaceHandler,
				);
			} else {
				swupEnableHandler = () => {
					if (window.swup?.hooks && swupContentReplaceHandler) {
						window.swup.hooks.on(
							"content:replace",
							swupContentReplaceHandler,
						);
					}
				};
				document.addEventListener("swup:enable", swupEnableHandler, {
					once: true,
				});
			}
		}

		pageLoadedHandler = () => {
			setupLazyLoad();
		};
		document.addEventListener("mizuki:page:loaded", pageLoadedHandler);

		window.addEventListener("beforeunload", cleanup);

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", () => {
				setupLazyLoad();
				setupSwupHooks();
			});
		} else {
			setupLazyLoad();
			setupSwupHooks();
		}

		themeObserver = new MutationObserver((mutations) => {
			mutations.forEach((mutation) => {
				if (
					mutation.attributeName === "class" ||
					mutation.attributeName === "data-theme"
				) {
					const isDark =
						document.documentElement.classList.contains("dark") ||
						document.documentElement
							.getAttribute("data-theme")
							?.includes("dark");
					const theme = isDark ? "dark" : "light";

					const iframe = document.querySelector(
						"iframe.giscus-frame",
					);
					if (iframe) {
						iframe.contentWindow?.postMessage(
							{ giscus: { setConfig: { theme } } },
							"https://giscus.app",
						);
					}
				}
			});
		});

		themeObserver.observe(document.documentElement, { attributes: true });

		window[GISCUS_CONTROLLER_KEY] = {
			destroy: cleanup,
		};
	})();
</script>

<style>
	.giscus-container {
		min-height: 200px;
	}
</style>
